# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.egg-info/

# virtual envs (any name)
env/
.venv/
env_*/
venv/

# PyInstaller artifacts (generated by CI, not committed)
backend/backend.spec
backend/build/
backend/dist/
src/build/
src/dist/
*.spec

# ── Node / Frontend ───────────────────────────────────────────────────────────
node_modules/
front-app/dist/
front-app/.env
front-app/.env.local
front-app/.env.*.local

# ── Rust / Tauri ──────────────────────────────────────────────────────────────
front-app/src-tauri/target/
front-app/src-tauri/gen/

# Sidecar binaries (generated by CI, not stored in git)
front-app/src-tauri/binaries/

# ── Generated output (algorithm results) ─────────────────────────────────────
templates/
resource/PublicTestCases/**/output_*.csv

# ── IDE / OS ──────────────────────────────────────────────────────────────────
.idea/
.vscode/
*.iml
.DS_Store
Thumbs.db

# ── Secrets / local config ────────────────────────────────────────────────────
backend/.env
.claude/settings.local.json

.claude/